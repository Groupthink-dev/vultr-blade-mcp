{
  "name": "vultr-blade-mcp",
  "version": "0.3.1",
  "description": "Vultr GPU compute infrastructure MCP server — VMs, bare metal, serverless inference, DNS, firewall, snapshots, billing with token-efficient defaults",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vultr-blade-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:http": "TRANSPORT=http tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "author": "groupthink-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Groupthink-dev/vultr-blade-mcp.git"
  },
  "homepage": "https://github.com/Groupthink-dev/vultr-blade-mcp",
  "keywords": [
    "mcp",
    "vultr",
    "gpu",
    "vm",
    "cloud",
    "model-context-protocol"
  ]
}
